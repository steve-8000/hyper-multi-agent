# Hyper Multi-Agent Proxy Configuration Template
# This file is a reference — actual config is generated by install.sh
# and stored in ~/.hyper-multi-agent/

# Backend server (cli-proxy-api-plus)
port: 8318
host: 127.0.0.1
auth-dir: "~/.cli-proxy-api"
debug: false
request-timeout: "10m"
request-retry: 3

# Frontend proxy (hyper-ai-proxy) is configured via CLI flags:
#   -port 8317
#   -bind 0.0.0.0          (when external access enabled)
#   -external-access        (when API key is set)
#   -api-key <key>          (authentication for external clients)
#   -ollama-enabled         (when Ollama URL is configured)
#   -ollama-url <url>       (Ollama server address)
